ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEXT_PUBLIC_SITE_URL=https://singular-onboarding-assistant.vercel.app

# Supabase vector store (RAG)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Voyage AI embeddings (512-dim, voyage-3-lite)
VOYAGE_API_KEY=your_voyage_api_key

# Admin route for adding knowledge base patterns
ADMIN_TOKEN=any-long-random-string

# Salesforce OAuth (Phase 2 Track B - Skill 1 Client Info integration).
# Create a Connected App in your Salesforce dev org with:
#   - Callback URL: {NEXT_PUBLIC_SITE_URL}/api/auth/salesforce/callback
#   - Scopes: api, refresh_token + offline_access, id + profile + email
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret
SALESFORCE_REDIRECT_URI=https://singular-onboarding-assistant.vercel.app/api/auth/salesforce/callback
# Optional - defaults to https://login.salesforce.com (use https://test.salesforce.com for sandboxes)
SALESFORCE_LOGIN_HOST=https://login.salesforce.com

# Atlassian OAuth 2.0 (3LO) for Phase 3 - Skill 4 Confluence MCP integration.
# Create an OAuth 2.0 (3LO) integration at developer.atlassian.com/console/myapps:
#   - Callback URL: {NEXT_PUBLIC_SITE_URL}/api/auth/atlassian/callback
#   - Add the Confluence Cloud API and grant read scopes
# The MCP integration uses Anthropic's mcp_servers connector pointed at
# https://mcp.atlassian.com/v1/mcp/authv2 with the SE's OAuth access token.
ATLASSIAN_CLIENT_ID=your_atlassian_oauth_client_id
ATLASSIAN_CLIENT_SECRET=your_atlassian_oauth_client_secret
ATLASSIAN_REDIRECT_URI=https://singular-onboarding-assistant.vercel.app/api/auth/atlassian/callback
# Optional - override the default MCP server URL or scope set
# ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp/authv2
# ATLASSIAN_OAUTH_SCOPES="read:confluence-content.summary read:confluence-content.all read:confluence-space.summary read:confluence-user search:confluence read:me offline_access"

# Session cookie encryption for per-SE Salesforce + Atlassian OAuth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must decode to exactly 32 bytes.
SESSION_SECRET=your_32_byte_base64_secret
