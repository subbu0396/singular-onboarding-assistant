ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEXT_PUBLIC_SITE_URL=https://singular-onboarding-assistant.vercel.app

# Supabase vector store (RAG)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Voyage AI embeddings (512-dim, voyage-3-lite)
VOYAGE_API_KEY=your_voyage_api_key

# Admin route for adding knowledge base patterns
ADMIN_TOKEN=any-long-random-string

# Salesforce OAuth (Phase 2 Track B - Skill 1 Client Info integration).
# Create a Connected App in your Salesforce dev org with:
#   - Callback URL: {NEXT_PUBLIC_SITE_URL}/api/auth/salesforce/callback
#   - Scopes: api, refresh_token + offline_access, id + profile + email
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret
SALESFORCE_REDIRECT_URI=https://singular-onboarding-assistant.vercel.app/api/auth/salesforce/callback
# Optional - defaults to https://login.salesforce.com (use https://test.salesforce.com for sandboxes)
SALESFORCE_LOGIN_HOST=https://login.salesforce.com

# Atlassian OAuth 2.0 (3LO) for Phase 3 - Skill 4 Confluence integration.
# Create an OAuth 2.0 (3LO) integration at developer.atlassian.com/console/myapps:
#   - Callback URL: https://YOUR-DEPLOYED-DOMAIN/api/auth/atlassian/callback
#     (add every Vercel alias you use, e.g. singular-onboarding-assistant.vercel.app)
#   - Add the Confluence Cloud API and grant read scopes
ATLASSIAN_CLIENT_ID=your_atlassian_oauth_client_id
ATLASSIAN_CLIENT_SECRET=your_atlassian_oauth_client_secret
# Optional legacy — redirect URI is now derived from the incoming request host
# ATLASSIAN_REDIRECT_URI=https://singular-onboarding-assistant.vercel.app/api/auth/atlassian/callback
# ATLASSIAN_USE_MCP_CONNECTOR=false
# Optional - override default MCP server URL or scope set (MCP path only)
# ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp/authv2
# ATLASSIAN_OAUTH_SCOPES="read:confluence-content.summary read:confluence-content.all read:confluence-space.summary read:confluence-user search:confluence read:me offline_access"

# Google Calendar OAuth (Phase 4 - Skill 5 Go-Live Timeline integration).
# Create an OAuth 2.0 Web client at console.cloud.google.com → APIs & Services
# → Credentials. Enable the Google Calendar API on the project first.
#   - Authorized redirect URI: https://YOUR-DEPLOYED-DOMAIN/api/auth/google/callback
#     (add every Vercel alias you use; localhost:3000 for dev)
#   - OAuth consent screen: add the openid, email, profile, and
#     https://www.googleapis.com/auth/calendar.readonly scopes
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Optional - override the requested scope set
# GOOGLE_OAUTH_SCOPES="openid email profile https://www.googleapis.com/auth/calendar.readonly"

# Shared engineering team calendar that Skill 5 queries for free/busy
# windows around the client's target go-live date. Usually the calendar's
# email address (e.g. eng-team@yourco.com) or its Google Calendar ID.
# When unset, Skill 5 only queries the SE's primary calendar.
ENGINEERING_CALENDAR_ID=eng-team@yourco.com

# GitHub OAuth (Phase 5 - Skill 2 Mobile SDK Setup grounding).
# Create an OAuth app at https://github.com/settings/developers:
#   - Authorization callback URL: https://YOUR-DEPLOYED-DOMAIN/api/auth/github/callback
#     (add every Vercel alias you use; localhost:3000 for dev)
# Default scopes are read:user + public_repo — broaden to `repo` if you
# need Skill 2 to read private client repos.
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Optional - override the requested scope set
# GITHUB_OAUTH_SCOPES="read:user repo"

# Render-hosted MCP service (Phase 6 — pushes the MCP-heavy skills off Vercel
# so they aren't bound by the serverless runtime budget).
#
# When both vars are set, Skill 2 (GitHub MCP) and Skill 4 (Confluence MCP)
# proxy through the Render service instead of trying to run Anthropic's MCP
# connector inside Vercel. When either is unset, both skills fall back to
# their Vercel-side REST paths (GitHub tool-using agent / Confluence REST).
MCP_SERVICE_URL=https://your-render-app.onrender.com
MCP_SERVICE_SECRET=any_long_random_string_shared_with_render

# Session cookie encryption for per-SE OAuth tokens (Salesforce, Atlassian, Google, GitHub).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must decode to exactly 32 bytes.
SESSION_SECRET=your_32_byte_base64_secret
